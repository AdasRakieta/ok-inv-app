<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.inventoryapp.ui.main.HomeFragment"
        android:label="@string/nav_home">
        
        <action
            android:id="@+id/action_home_to_products"
            app:destination="@id/productsListFragment" />
        
        <action
            android:id="@+id/action_home_to_bulk_add"
            app:destination="@id/bulkAddFragment" />
    </fragment>

    <fragment
        android:id="@+id/productsListFragment"
        android:name="com.example.inventoryapp.ui.products.ProductsListFragment"
        android:label="Produkty">
        
        <action
            android:id="@+id/action_products_to_details"
            app:destination="@id/productDetailsFragment" />
        
        <action
            android:id="@+id/action_products_to_add_edit"
            app:destination="@id/addEditProductFragment" />
    </fragment>
    
    <fragment
        android:id="@+id/productDetailsFragment"
        android:name="com.example.inventoryapp.ui.products.ProductDetailsFragment"
        android:label="Szczegóły produktu">
        
        <argument
            android:name="productId"
            app:argType="long" />
        
        <action
            android:id="@+id/action_details_to_add_edit"
            app:destination="@id/addEditProductFragment" />
    </fragment>
    
    <fragment
        android:id="@+id/addEditProductFragment"
        android:name="com.example.inventoryapp.ui.products.AddEditProductFragment"
        android:label="Product">
        
        <argument
            android:name="productId"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>

    <fragment
        android:id="@+id/bulkAddFragment"
        android:name="com.example.inventoryapp.ui.bulkadd.BulkAddFragment"
        android:label="Masowe Dodawanie" />

</navigation>
