<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- GitHub-inspired dark theme -->
    <style name="Theme.InventoryApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Apply our form input style app-wide -->
        <item name="textInputStyle">@style/Widget.App.FormInput</item>
        <!-- Ensure EditText (including TextInputEditText) uses our edit text defaults -->
        <item name="editTextStyle">@style/Widget.App.EditText</item>
    </style>
    
    <style name="Widget.App.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">6dp</item>
    </style>
    
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">6dp</item>
    </style>
    
    <style name="Widget.App.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">6dp</item>
    </style>

    <!-- Splash theme showing centered logo on brand background -->
    <style name="Theme.InventoryApp.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Fullscreen Dialog Style -->
    <style name="FullScreenDialogStyle" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>

    <!-- Form card and input styles to keep forms visually consistent -->
    <style name="Widget.App.FormCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/home_card_background</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeColor">@color/home_card_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
    </style>

    <style name="Widget.App.FormInput" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundMode">filled</item>
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintEnabled">false</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <!-- Centralized EditText style for consistent paddings and heights -->
    <style name="Widget.App.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <!-- Outlined variants for inputs (dropdowns, outlined boxes) -->
    <style name="Widget.App.FormInput.Outlined" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/home_card_background</item>
        <item name="boxStrokeColor">@color/home_card_stroke</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.App.FormInput.Outlined.ExposedDropdownMenu" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/home_card_background</item>
        <item name="boxStrokeColor">@color/home_card_stroke</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

</resources>
