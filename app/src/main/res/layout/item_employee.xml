<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/employeeCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#FFFFFF"
    app:cardElevation="2dp"
    app:cardCornerRadius="12dp"
    app:strokeColor="#E5E7EB"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Employee Header with actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Selection Checkbox -->
            <CheckBox
                android:id="@+id/employeeCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginEnd="12dp"
                android:buttonTint="@color/primary" />

            <!-- Employee Icon -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/employeeIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardBackgroundColor="#E3F2FD"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/employeeInitials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#1565C0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="JK" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/employeeName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jan Kowalski"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/employeeDepartment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IT"
                        android:textSize="15sp"
                        android:textColor="#0EA5E9"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" • "
                        android:textSize="15sp"
                        android:textColor="#9CA3AF"
                        android:paddingHorizontal="4dp" />

                    <TextView
                        android:id="@+id/employeePosition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Programista"
                        android:textSize="13sp"
                        android:textColor="#374151"
                        android:maxLines="1" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Assigned Equipment Badge -->
        <LinearLayout
            android:id="@+id/assignedCountContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFF3E0"
            android:padding="10dp"
            android:layout_marginTop="8dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦"
                android:textSize="13sp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/assignedCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="5 urządzeń"
                android:textSize="13sp"
                android:textColor="#E65100"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Contact Info -->
        <TextView
            android:id="@+id/employeeContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📧 jan.kowalski@firma.pl"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:layout_marginTop="8dp"
            android:visibility="visible" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
