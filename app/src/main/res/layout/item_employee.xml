<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="12dp"
    android:checkable="true"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Checkbox for selection -->
        <CheckBox
            android:id="@+id/employeeCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Employee Icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/employeeIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="#E3F2FD"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toEndOf="@id/employeeCheckbox"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/employeeInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#1565C0"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="JK" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Employee Name -->
        <TextView
            android:id="@+id/employeeName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/employeeIcon"
            app:layout_constraintTop_toTopOf="@id/employeeIcon"
            tools:text="Jan Kowalski" />

        <!-- Department and Position -->
        <TextView
            android:id="@+id/employeeDepartment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#212121"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/employeeIcon"
            app:layout_constraintTop_toBottomOf="@id/employeeName"
            tools:text="IT • Programista" />

        <!-- Assigned Equipment Count -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/assignedCountCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#FFF3E0"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toEndOf="@id/employeeCheckbox"
            app:layout_constraintTop_toBottomOf="@id/employeeIcon">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/assignedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="#E65100"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="5 urządzeń" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Contact Info -->
        <TextView
            android:id="@+id/employeeContact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#757575"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/assignedCountCard"
            app:layout_constraintTop_toBottomOf="@id/employeeIcon"
            tools:text="📧 jan.kowalski@firma.pl" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
