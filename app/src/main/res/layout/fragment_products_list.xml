<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7">

    <!-- Header -->
    <TextView
        android:id="@+id/productsToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Produkty"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:padding="16dp"
        android:background="#F2F4F7"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Search Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeColor="#E5E7EB"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/productsToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="Search"
                app:tint="#6B7280" />

            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="Szukaj po nazwie lub numerze"
                android:inputType="text"
                android:maxLines="1"
                android:textSize="16sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Filter and Sort Bar -->
    <LinearLayout
        android:id="@+id/filterSortBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/statsButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:padding="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="Statystyki"
            app:icon="@android:drawable/ic_menu_info_details"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Kategoria"
            android:textSize="14sp"
            android:maxLines="1"
            android:textAllCaps="false"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"
            android:textColor="#0F172A" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/statusFilterButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Status"
            android:textSize="14sp"
            android:maxLines="1"
            android:textAllCaps="false"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"
            android:textColor="#0F172A" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sortButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="Sortuj"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp" />

    </LinearLayout>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyStateLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/filterSortBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="48sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Brak produktow"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dodaj pierwszy produkt, aby zaczac"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/emptyAddButton"
            style="@style/Widget.App.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dodaj produkt"
            android:textAllCaps="false" />

    </LinearLayout>

    <!-- Products RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/productsRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/filterSortBar"
        app:layout_constraintBottom_toTopOf="@id/selectionPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Selection Panel (hidden by default) - Compact with emoji buttons -->
    <LinearLayout
        android:id="@+id/selectionPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp"
        android:paddingHorizontal="12dp"
        android:background="@color/surface"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/selectionCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Zaznaczono: 0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:ellipsize="end" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/selectAllButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Wszystkie"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:contentDescription="Zaznacz wszystko"
            android:paddingHorizontal="8dp"
            android:minWidth="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteSelectedButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🗑️"
            android:textSize="24sp"
            android:contentDescription="Usuń zaznaczone"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

    <!-- FAB Menu Overlay -->
    <View
        android:id="@+id/fabMenuOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#88000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- FAB Menu Option - Masowe dodawanie -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bulkAddCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardElevation="4dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#10B981"
        app:layout_constraintBottom_toTopOf="@id/singleAddCard"
        app:layout_constraintEnd_toEndOf="@id/addProductFab"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/bulkAddLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masowe dodawanie według wzoru"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/bulkAddIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_upload"
                android:contentDescription="Masowe dodawanie"
                app:tint="@color/white"
                android:padding="8dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- FAB Menu Option - Jeden produkt -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/singleAddCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardElevation="4dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#8B5CF6"
        app:layout_constraintBottom_toTopOf="@id/addProductFab"
        app:layout_constraintEnd_toEndOf="@id/addProductFab"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/singleAddLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dodaj jeden produkt"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/singleAddIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_add"
                android:contentDescription="Dodaj jeden produkt"
                app:tint="@color/white"
                android:padding="8dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Main Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addProductFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Add Product"
        app:tint="@color/white"
        app:backgroundTint="#0EA5E9"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>