<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNavRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- FAB Menu Overlay (full screen, behind bottom nav) -->
    <View
        android:id="@+id/fabMenuOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- FAB Menu Items Container -->
    <FrameLayout
        android:id="@+id/fabMenuContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Companies Button (Left) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/fabMenuCompanies"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="200dp"
            android:layout_marginEnd="75dp"
            android:visibility="gone"
            android:foreground="@drawable/ripple_fab_menu"
            android:clickable="true"
            android:focusable="true"
            app:cardElevation="6dp"
            app:cardCornerRadius="37.5dp"
            app:cardBackgroundColor="@color/orders_accent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_fab_companies"
                    android:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bottom_nav_menu_companies"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Points Button (Center Top) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/fabMenuPoints"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="210dp"
            android:visibility="gone"
            android:foreground="@drawable/ripple_fab_menu"
            android:clickable="true"
            android:focusable="true"
            app:cardElevation="6dp"
            app:cardCornerRadius="40dp"
            app:cardBackgroundColor="@color/info">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_fab_points"
                    android:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Punkty"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Settings Button (Right) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/fabMenuSettings"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="200dp"
            android:layout_marginStart="75dp"
            android:visibility="gone"
            android:foreground="@drawable/ripple_fab_menu"
            android:clickable="true"
            android:focusable="true"
            app:cardElevation="6dp"
            app:cardCornerRadius="37.5dp"
            app:cardBackgroundColor="@color/warehouse_accent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_fab_settings"
                    android:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bottom_nav_menu_settings"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_home_bottom_nav"
        android:elevation="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/navProducts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navProductsIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_products"
                android:tint="@color/home_nav_icon" />

            <TextView
                android:id="@+id/navProductsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/bottom_nav_products"
                android:textColor="@color/home_nav_icon"
                android:textSize="10sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navEmployees"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navEmployeesIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_employees"
                android:tint="@color/home_nav_icon" />

            <TextView
                android:id="@+id/navEmployeesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/bottom_nav_employees"
                android:textColor="@color/home_nav_icon"
                android:textSize="10sp" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="@drawable/ripple_home_button"
            android:foregroundGravity="center"
            android:gravity="center">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navHomeButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:translationY="-18dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/home_primary">

                <ImageView
                    android:id="@+id/navHomeIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="14dp"
                    android:src="@drawable/ic_nav_home"
                    android:tint="@color/white" />

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <LinearLayout
            android:id="@+id/navWarehouse"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navWarehouseIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_warehouse"
                android:tint="@color/home_nav_icon" />

            <TextView
                android:id="@+id/navWarehouseLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/bottom_nav_warehouse"
                android:textColor="@color/home_nav_icon"
                android:textSize="10sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navMore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navMoreIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_more_vertical"
                android:tint="@color/home_nav_icon" />

            <TextView
                android:id="@+id/navMoreLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/bottom_nav_more"
                android:textColor="@color/home_nav_icon"
                android:textSize="10sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Close Button (displayed when menu is open) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_global_add"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="64dp"
        android:translationY="-9dp"
        app:srcCompat="@drawable/ic_add"
        android:contentDescription="@string/action_add"
        android:tint="@color/white"
        app:backgroundTint="@color/home_primary"
        app:useCompatPadding="true" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/fabMenuClose"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:foreground="@drawable/ripple_fab_menu"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/background_secondary">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp"
            android:src="@drawable/ic_fab_close" />

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
