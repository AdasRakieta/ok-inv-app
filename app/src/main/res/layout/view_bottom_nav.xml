<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNavRoot"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:background="@drawable/bg_home_bottom_nav"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:elevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/navProducts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navProductsIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_products"
                android:tint="@color/home_nav_icon" />

            <TextView
                android:id="@+id/navProductsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Produkty"
                android:textColor="@color/home_nav_icon"
                android:textSize="10sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navEmployees"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navEmployeesIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_employees"
                android:tint="@color/home_nav_icon" />

            <TextView
                android:id="@+id/navEmployeesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Pracownicy"
                android:textColor="@color/home_nav_icon"
                android:textSize="10sp" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="@drawable/ripple_home_button"
            android:foregroundGravity="center"
            android:gravity="center">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navHomeButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:translationY="-18dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/home_primary">

                <ImageView
                    android:id="@+id/navHomeIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="14dp"
                    android:src="@drawable/ic_nav_home"
                    android:tint="@color/white" />

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <LinearLayout
            android:id="@+id/navWarehouse"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navWarehouseIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_warehouse"
                android:tint="@color/home_nav_icon" />

            <TextView
                android:id="@+id/navWarehouseLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Magazyn"
                android:textColor="@color/home_nav_icon"
                android:textSize="10sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navSettingsIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_settings"
                android:tint="@color/home_nav_icon" />

            <TextView
                android:id="@+id/navSettingsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ustawienia"
                android:textColor="@color/home_nav_icon"
                android:textSize="10sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
