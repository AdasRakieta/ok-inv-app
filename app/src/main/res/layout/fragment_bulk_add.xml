<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Masowe Dodawanie Produktów"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Skanuj numery seryjne urządzeń skanerem"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp" />

            <!-- Template Display (Read-only) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/templateEmojiText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦"
                    android:textSize="28sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/selectedTemplateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nie wybrano"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- Batch Settings -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.App.FormCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ustawienia dodawania"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp" />

                    <!-- Status dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/bulkStatusLayout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Status"
                        app:boxBackgroundColor="@color/surface"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        android:layout_marginBottom="12dp">

                        <AutoCompleteTextView
                            android:id="@+id/bulkStatusInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:inputType="none" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Location dropdown (visible only for Magazyn) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/bulkLocationLayout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Lokalizacja (dla statusu Magazyn)"
                        app:boxBackgroundColor="@color/surface"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        android:layout_marginBottom="12dp"
                        android:visibility="visible">

                        <AutoCompleteTextView
                            android:id="@+id/bulkLocationInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:inputType="none" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Employee dropdown (visible only for Assigned) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/bulkEmployeeLayout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Pracownik (dla statusu Przypisane)"
                        app:boxBackgroundColor="@color/surface"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/text_secondary"
                        android:layout_marginBottom="4dp"
                        android:visibility="gone">

                        <AutoCompleteTextView
                            android:id="@+id/bulkEmployeeInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:inputType="none" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/bulkLocationHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status 'Magazyn' wymaga wyboru lokalizacji"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary"
                        android:visibility="visible"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/bulkEmployeeHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status 'Przypisane' wymaga wyboru pracownika"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Scan Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.App.FormCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Skanuj Numery Seryjne"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                    <!-- Dynamic Products Input Container - grows to max 3 visible items then scrolls -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="220dp"
                        android:scrollbars="vertical"
                        android:fadingEdge="vertical"
                        android:fadingEdgeLength="12dp">

                        <LinearLayout
                            android:id="@+id/productsInputContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="8dp" />

                    </ScrollView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 Po każdym skanowaniu pojawi się nowe pole"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Status Messages -->
            <TextView
                android:id="@+id/lastScannedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gotowy do skanowania..."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:padding="8dp"
                android:background="@drawable/rounded_background"
                android:backgroundTint="@color/surface" />

            <!-- Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/scannedCountText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Zeskanowano: 0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </LinearLayout>

            </LinearLayout>

    </ScrollView>

    <!-- Fixed Bottom Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/background"
        android:elevation="8dp">

        <Button
            android:id="@+id/saveAllButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zapisz Wszystkie Produkty"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="12dp"
            app:backgroundTint="@color/success" />

    </LinearLayout>

</LinearLayout>
